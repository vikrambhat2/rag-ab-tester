# ── WatsonX AI ────────────────────────────────────────────────────────────── #
# Required: IBM Cloud API key
WATSONX_APIKEY=your_ibm_cloud_api_key_here

# Required: WatsonX project ID (found in your WatsonX project settings)
WATSONX_PROJECT_ID=your_project_id_here

# Optional: WatsonX service endpoint (default: us-south)
# Other regions: eu-de, eu-gb, jp-tok, au-syd
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional: LLM model ID for generation and judging
# Examples: ibm/granite-3-8b-instruct, meta-llama/llama-3-2-3b-instruct
WATSONX_LLM_MODEL_ID=ibm/granite-3-8b-instruct

# Optional: Default embedding model ID (used by all experiments unless overridden)
# Examples: ibm/slate-125m-english-rtrvr, ibm/slate-30m-english-rtrvr
WATSONX_EMBED_MODEL_ID=ibm/slate-125m-english-rtrvr-v2
